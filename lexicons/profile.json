{
  "lexicon": 1,
  "id": "st.lifepo.profile",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a user's do-life profile including bio and life events.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": {
            "type": "string",
            "description": "The DID or handle of the user."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["handle", "bio", "lifeEvents"],
          "properties": {
            "handle": { "type": "string" },
            "bio": { "type": "string" },
            "avatar": { "type": "string" }
          }
        }
      }
    },
    "lifeEvent": {
      "type": "object",
      "description": "A single life event entry.",
      "required": ["title", "startDate"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "datetime" },
        "endDate": { "type": "string", "format": "datetime" }
      }
    }
  }
}
